#!/usr/bin/env bash
set -euo pipefail

resolve_script_path() {
  local source_path="$1"
  local source_dir target

  while [[ -L "${source_path}" ]]; do
    source_dir=$(cd -P -- "$(dirname -- "${source_path}")" && pwd)
    target=$(readlink "${source_path}")

    if [[ "${target}" == /* ]]; then
      source_path="${target}"
    else
      source_path="${source_dir}/${target}"
    fi
  done

  cd -P -- "$(dirname -- "${source_path}")" && pwd
}

SCRIPT_DIR=$(resolve_script_path "${BASH_SOURCE[0]}")
REPO_ROOT=$(cd -P -- "${SCRIPT_DIR}/.." && pwd)

if [[ -f "${REPO_ROOT}/council.conf" ]]; then
  # shellcheck disable=SC1091
  source "${REPO_ROOT}/council.conf"
fi

BASE_WINDOW_NAME="${MAESTRO_COUNCIL_WINDOW:-maestro-council}"
BASE_CODEX_LABEL="${MAESTRO_COUNCIL_CODEX_LABEL:-council-codex}"
BASE_CC_LABEL="${MAESTRO_COUNCIL_CC_LABEL:-council-cc}"
BASE_AMP_LABEL="${MAESTRO_COUNCIL_AMP_LABEL:-council-amp}"
BASE_ORCHESTRATOR_LABEL="${MAESTRO_COUNCIL_ORCHESTRATOR_LABEL:-council-orchestrator}"

CODEX_CMD="${MAESTRO_COUNCIL_CODEX_CMD:-codex}"
CC_CMD="${MAESTRO_COUNCIL_CC_CMD:-claude}"
AMP_CMD="${MAESTRO_COUNCIL_AMP_CMD:-amp}"

COUNCIL_HOME_OVERRIDE="${MAESTRO_COUNCIL_HOME:-}"
COUNCIL_HOME=""
RUNS_DIR=""
TMP_DIR=""
DEFAULT_TIMEOUT="${MAESTRO_COUNCIL_TIMEOUT:-900}"
POLL_INTERVAL="${MAESTRO_COUNCIL_POLL_INTERVAL:-0.5}"
MAX_REVIEW_ROUNDS="${MAESTRO_COUNCIL_MAX_REVIEW_ROUNDS:-2}"
AGENT_READY_TIMEOUT="${MAESTRO_COUNCIL_AGENT_READY_TIMEOUT:-20}"
ORCHESTRATE_IN_PANE="${MAESTRO_COUNCIL_ORCHESTRATE_IN_PANE:-1}"
ORCHESTRATOR_PANE_LINES="${MAESTRO_COUNCIL_ORCHESTRATOR_PANE_LINES:-14}"
ORCHESTRATOR_PANE_TARGET="${MAESTRO_COUNCIL_ORCHESTRATOR_PANE_TARGET:-current}"
ORCHESTRATOR_PANE_WIDTH="${MAESTRO_COUNCIL_ORCHESTRATOR_PANE_WIDTH:-20}"
OUTPUT_COLOR_MODE="${MAESTRO_COUNCIL_COLOR:-auto}"

CURRENT_RUN_DIR=""
CURRENT_RUN_ID=""
CURRENT_MEMBER_LABELS=""
COUNCIL_INSTANCE=""
INSTANCE_IS_EXPLICIT=0
WINDOW_NAME=""
CODEX_LABEL=""
CC_LABEL=""
AMP_LABEL=""
ORCHESTRATOR_LABEL=""
RUN_DIR=""
RUN_ID=""
RUN_TASK=""
RUN_WORKSPACE=""
RUN_PLAN_DIR=""
RUN_CRITIQUE_DIR=""
RUN_REVIEW_DIR=""
RUN_IMPL_DIR=""
RUN_INSTRUCTION_DIR=""
RUN_BUNDLE_DIR=""
RUN_CC_REVIEW_PATH=""
RUN_AMP_REVIEW_PATH=""
RUN_CC_VERDICT=""
RUN_AMP_VERDICT=""
RUN_PHASE=""
RUN_TARGET=""

# Cached pane IDs (populated by cache_pane_ids)
PANE_ID_CODEX=""
PANE_ID_CC=""
PANE_ID_AMP=""
PANE_ID_ORCHESTRATOR=""

STYLE_RESET=""
STYLE_BOLD=""
STYLE_DIM=""
STYLE_HEADER=""
STYLE_KEY=""
STYLE_STAGE=""
STYLE_PATH=""
STYLE_SUCCESS=""
STYLE_WARN=""
STYLE_ERROR=""

configure_output_style() {
  local enabled=0

  if [[ -n "${NO_COLOR:-}" ]]; then
    OUTPUT_COLOR_MODE="never"
  fi

  case "${OUTPUT_COLOR_MODE}" in
    always|ALWAYS)
      enabled=1
      ;;
    never|NEVER)
      enabled=0
      ;;
    auto|AUTO|"")
      if [[ -t 1 && "${TERM:-dumb}" != "dumb" ]]; then
        enabled=1
      fi
      ;;
  esac

  if (( enabled == 0 )); then
    return 0
  fi

  STYLE_RESET=$'\033[0m'
  STYLE_BOLD=$'\033[1m'
  STYLE_DIM=$'\033[2m'
  STYLE_HEADER=$'\033[1;36m'
  STYLE_KEY=$'\033[1;34m'
  STYLE_STAGE=$'\033[1;35m'
  STYLE_PATH=$'\033[0;37m'
  STYLE_SUCCESS=$'\033[1;32m'
  STYLE_WARN=$'\033[1;33m'
  STYLE_ERROR=$'\033[1;31m'
}

configure_output_style

print_heading() {
  printf '%b%s%b\n' "${STYLE_HEADER}" "$1" "${STYLE_RESET}"
}

print_field() {
  printf '%b%s:%b %s\n' "${STYLE_KEY}" "$1" "${STYLE_RESET}" "$2"
}

print_path_field() {
  printf '%b%s:%b\n' "${STYLE_KEY}" "$1" "${STYLE_RESET}"
  printf '  %b%s%b\n' "${STYLE_PATH}" "$2" "${STYLE_RESET}"
}

print_note_line() {
  printf '%b%s%b\n' "${STYLE_DIM}" "$1" "${STYLE_RESET}"
}

print_stage_line() {
  printf '%b[council]%b %s\n' "${STYLE_STAGE}" "${STYLE_RESET}" "$1"
}

format_verdict() {
  local verdict="${1:-UNKNOWN}"

  case "${verdict}" in
    LGTM)
      printf '%b%s%b' "${STYLE_SUCCESS}" "${verdict}" "${STYLE_RESET}"
      ;;
    REVISE)
      printf '%b%s%b' "${STYLE_WARN}" "${verdict}" "${STYLE_RESET}"
      ;;
    *)
      printf '%s' "${verdict}"
      ;;
  esac
}

print_review_item() {
  local path="$1"
  local verdict="$2"
  local formatted_verdict

  formatted_verdict=$(format_verdict "${verdict}")
  printf '  - %b%s%b (%b)\n' "${STYLE_PATH}" "${path}" "${STYLE_RESET}" "${formatted_verdict}"
}

die() {
  printf '%berror:%b %s\n' "${STYLE_ERROR}" "${STYLE_RESET}" "$*" >&2
  exit 1
}

normalize_instance_name() {
  local raw="${1:-default}"
  local normalized

  normalized=$(
    printf '%s' "${raw}" \
      | tr '[:upper:]' '[:lower:]' \
      | tr -cs '[:alnum:]_.-' '-' \
      | sed -E 's/^-+//; s/-+$//; s/-{2,}/-/g'
  )
  [[ -n "${normalized}" ]] || die "council instance must contain at least one letter or number"
  printf '%s\n' "${normalized}"
}

apply_council_instance() {
  local requested="${1:-default}"
  local suffix=""

  COUNCIL_INSTANCE=$(normalize_instance_name "${requested}")
  if [[ "${COUNCIL_INSTANCE}" != "default" ]]; then
    suffix="-${COUNCIL_INSTANCE}"
  fi

  WINDOW_NAME="${BASE_WINDOW_NAME}${suffix}"
  CODEX_LABEL="${BASE_CODEX_LABEL}${suffix}"
  CC_LABEL="${BASE_CC_LABEL}${suffix}"
  AMP_LABEL="${BASE_AMP_LABEL}${suffix}"
  ORCHESTRATOR_LABEL="${BASE_ORCHESTRATOR_LABEL}${suffix}"
}

window_name_for_instance() {
  local requested="${1:-default}"
  local instance suffix=""

  instance=$(normalize_instance_name "${requested}")
  if [[ "${instance}" != "default" ]]; then
    suffix="-${instance}"
  fi

  printf '%s\n' "${BASE_WINDOW_NAME}${suffix}"
}

need_bin() {
  command -v "$1" >/dev/null 2>&1 || die "$1 is required"
}

require_tmux() {
  [[ -n "${TMUX:-}" ]] || die "run this inside tmux"
  need_bin tmux
  need_bin tmux-bridge
  need_bin perl

  # Export socket path so tmux-bridge skips auto-detection on every call
  export TMUX_BRIDGE_SOCKET="${TMUX_BRIDGE_SOCKET:-${TMUX%%,*}}"

  # Verify tmux-bridge supports one-way send for council dispatch messages.
  tmux-bridge help 2>/dev/null | grep -Eq '^[[:space:]]*send <target> <text>[[:space:]]' \
    || die "tmux-bridge does not support 'send'. Please upgrade tmux-bridge."
}

ensure_dirs() {
  mkdir -p "${RUNS_DIR}" "${TMP_DIR}"
}

set_council_paths() {
  local workspace="$1"

  if [[ -n "${COUNCIL_HOME_OVERRIDE}" ]]; then
    COUNCIL_HOME="${COUNCIL_HOME_OVERRIDE}"
  else
    COUNCIL_HOME="${workspace}/council-out"
  fi

  RUNS_DIR="${COUNCIL_HOME}/runs"
  TMP_DIR="${COUNCIL_HOME}/tmp"
}

read_file_contents() {
  local path="$1"
  [[ -f "${path}" ]] || die "missing file: ${path}"
  perl -0ne 'print' "${path}"
}

set_run_context() {
  local run_id="$1"
  local run_dir="$2"
  local workspace="$3"
  local task="$4"

  RUN_ID="${run_id}"
  RUN_DIR="${run_dir}"
  RUN_WORKSPACE="${workspace}"
  RUN_TASK="${task}"
  RUN_PLAN_DIR="${run_dir}/plans"
  RUN_CRITIQUE_DIR="${run_dir}/critiques"
  RUN_REVIEW_DIR="${run_dir}/reviews"
  RUN_IMPL_DIR="${run_dir}/implementation"
  RUN_INSTRUCTION_DIR="${run_dir}/instructions"
  RUN_BUNDLE_DIR="${run_dir}/bundles"
  RUN_CC_REVIEW_PATH=""
  RUN_AMP_REVIEW_PATH=""
  RUN_CC_VERDICT=""
  RUN_AMP_VERDICT=""
  RUN_PHASE=""
  RUN_TARGET=""
}

run_target_path() {
  printf '%s\n' "${RUN_DIR}/target.txt"
}

run_phase_path() {
  printf '%s\n' "${RUN_DIR}/phase.txt"
}

run_workspace_snapshot_path() {
  printf '%s\n' "${RUN_DIR}/workspace.snapshot.txt"
}

write_run_target() {
  local target="$1"
  RUN_TARGET="${target}"
  [[ -n "${RUN_DIR}" ]] || return 0
  printf '%s\n' "${target}" > "$(run_target_path)"
}

read_run_target() {
  local path
  path=$(run_target_path)

  if [[ -f "${path}" ]]; then
    RUN_TARGET=$(read_file_contents "${path}")
  else
    RUN_TARGET="complete"
  fi

  printf '%s\n' "${RUN_TARGET}"
}

infer_run_phase() {
  if [[ -s "${RUN_IMPL_DIR}/codex.md" ]]; then
    if [[ "$(next_stage_for_run)" == "complete" ]]; then
      printf 'complete\n'
    else
      printf 'execution\n'
    fi
    return
  fi

  if [[ -s "${RUN_DIR}/plan.final.md" ]]; then
    printf 'plan-complete\n'
    return
  fi

  printf 'planning\n'
}

write_run_phase() {
  local phase="$1"
  RUN_PHASE="${phase}"
  [[ -n "${RUN_DIR}" ]] || return 0
  printf '%s\n' "${phase}" > "$(run_phase_path)"
  printf '%s\tphase:%s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "${phase}" >> "${RUN_DIR}/progress.log"
}

read_run_phase() {
  local path
  path=$(run_phase_path)

  if [[ -f "${path}" ]]; then
    RUN_PHASE=$(read_file_contents "${path}")
  else
    RUN_PHASE=$(infer_run_phase)
  fi

  printf '%s\n' "${RUN_PHASE}"
}

workspace_git_present() {
  git -C "${RUN_WORKSPACE}" rev-parse --is-inside-work-tree >/dev/null 2>&1
}

workspace_git_branch() {
  git -C "${RUN_WORKSPACE}" rev-parse --abbrev-ref HEAD 2>/dev/null || true
}

workspace_git_head() {
  git -C "${RUN_WORKSPACE}" rev-parse HEAD 2>/dev/null || true
}

workspace_git_dirty() {
  if [[ -n "$(git -C "${RUN_WORKSPACE}" status --short 2>/dev/null)" ]]; then
    printf 'dirty\n'
  else
    printf 'clean\n'
  fi
}

write_workspace_snapshot() {
  local path branch head dirty
  path=$(run_workspace_snapshot_path)

  if workspace_git_present; then
    branch=$(workspace_git_branch)
    head=$(workspace_git_head)
    dirty=$(workspace_git_dirty)
    {
      printf 'workspace=%s\n' "${RUN_WORKSPACE}"
      printf 'git=yes\n'
      printf 'branch=%s\n' "${branch}"
      printf 'head=%s\n' "${head}"
      printf 'dirty=%s\n' "${dirty}"
    } > "${path}"
    return
  fi

  {
    printf 'workspace=%s\n' "${RUN_WORKSPACE}"
    printf 'git=no\n'
    printf 'branch=\n'
    printf 'head=\n'
    printf 'dirty=\n'
  } > "${path}"
}

workspace_snapshot_field() {
  local path="$1"
  local field="$2"

  awk -F= -v field="${field}" '$1 == field { print substr($0, length($1) + 2); exit }' "${path}"
}

check_workspace_snapshot() {
  local path recorded_workspace recorded_git recorded_branch recorded_head recorded_dirty
  local current_workspace current_git current_branch current_head current_dirty
  local drift=0

  path=$(run_workspace_snapshot_path)
  [[ -f "${path}" ]] || return 0

  recorded_workspace=$(workspace_snapshot_field "${path}" "workspace")
  recorded_git=$(workspace_snapshot_field "${path}" "git")
  recorded_branch=$(workspace_snapshot_field "${path}" "branch")
  recorded_head=$(workspace_snapshot_field "${path}" "head")
  recorded_dirty=$(workspace_snapshot_field "${path}" "dirty")

  current_workspace="${RUN_WORKSPACE}"
  if workspace_git_present; then
    current_git="yes"
    current_branch=$(workspace_git_branch)
    current_head=$(workspace_git_head)
    current_dirty=$(workspace_git_dirty)
  else
    current_git="no"
    current_branch=""
    current_head=""
    current_dirty=""
  fi

  if [[ "${recorded_workspace}" != "${current_workspace}" ]]; then
    printf 'workspace snapshot mismatch: recorded workspace %s, current workspace %s\n' "${recorded_workspace}" "${current_workspace}" >&2
    drift=1
  fi
  if [[ "${recorded_git}" != "${current_git}" ]]; then
    printf 'workspace snapshot mismatch: recorded git=%s, current git=%s\n' "${recorded_git}" "${current_git}" >&2
    drift=1
  fi
  if [[ "${recorded_branch}" != "${current_branch}" ]]; then
    printf 'workspace snapshot mismatch: recorded branch=%s, current branch=%s\n' "${recorded_branch}" "${current_branch}" >&2
    drift=1
  fi
  if [[ "${recorded_head}" != "${current_head}" ]]; then
    printf 'workspace snapshot mismatch: recorded head=%s, current head=%s\n' "${recorded_head}" "${current_head}" >&2
    drift=1
  fi
  if [[ "${recorded_dirty}" != "${current_dirty}" ]]; then
    printf 'workspace snapshot warning: recorded dirty=%s, current dirty=%s\n' "${recorded_dirty}" "${current_dirty}" >&2
  fi

  return "${drift}"
}

log_run_stage() {
  local stage="$1"
  local message="$2"

  if [[ -n "${RUN_DIR}" ]]; then
    printf '%s\n' "${stage}" > "${RUN_DIR}/stage.txt"
    printf '%s\t%s\n' "$(date '+%Y-%m-%d %H:%M:%S')" "${stage}" >> "${RUN_DIR}/progress.log"
  fi

  print_stage_line "${message}"
}

setup_current_run_tracking() {
  CURRENT_RUN_DIR="${RUN_DIR}"
  CURRENT_RUN_ID="${RUN_ID}"
  CURRENT_MEMBER_LABELS="${CODEX_LABEL} ${CC_LABEL} ${AMP_LABEL}"
}

finalize_run_success() {
  trap - EXIT
  cleanup_run 0
}

run_members() {
  printf '%s\n' "codex:${CODEX_LABEL}" "cc:${CC_LABEL}" "amp:${AMP_LABEL}"
}

plans_complete() {
  [[ -s "${RUN_PLAN_DIR}/codex.md" && -s "${RUN_PLAN_DIR}/cc.md" && -s "${RUN_PLAN_DIR}/amp.md" ]]
}

critiques_complete() {
  [[ -s "${RUN_CRITIQUE_DIR}/codex.md" && -s "${RUN_CRITIQUE_DIR}/cc.md" && -s "${RUN_CRITIQUE_DIR}/amp.md" ]]
}

review_round_complete() {
  local round="$1"
  [[ -s "${RUN_REVIEW_DIR}/cc.round-${round}.md" && -s "${RUN_REVIEW_DIR}/amp.round-${round}.md" ]]
}

review_round_verdicts() {
  local round="$1"
  RUN_CC_REVIEW_PATH="${RUN_REVIEW_DIR}/cc.round-${round}.md"
  RUN_AMP_REVIEW_PATH="${RUN_REVIEW_DIR}/amp.round-${round}.md"
  RUN_CC_VERDICT=$(review_verdict "${RUN_CC_REVIEW_PATH}")
  RUN_AMP_VERDICT=$(review_verdict "${RUN_AMP_REVIEW_PATH}")
}

next_stage_for_run() {
  local round target="complete"

  if [[ -n "${RUN_DIR}" ]]; then
    target=$(read_run_target)
  fi

  if ! plans_complete; then
    printf 'plans\n'
    return
  fi

  if ! critiques_complete; then
    printf 'critiques\n'
    return
  fi

  if [[ ! -s "${RUN_DIR}/plan.final.md" ]]; then
    printf 'final-plan\n'
    return
  fi

  if [[ "${target}" == "plan" ]]; then
    printf 'complete\n'
    return
  fi

  if [[ ! -s "${RUN_IMPL_DIR}/codex.md" ]]; then
    printf 'implementation\n'
    return
  fi

  for (( round = 1; round <= MAX_REVIEW_ROUNDS; round++ )); do
    if ! review_round_complete "${round}"; then
      printf 'reviews-round-%s\n' "${round}"
      return
    fi

    review_round_verdicts "${round}"
    if [[ "${RUN_CC_VERDICT}" == "LGTM" && "${RUN_AMP_VERDICT}" == "LGTM" ]]; then
      printf 'complete\n'
      return
    fi

    if (( round >= MAX_REVIEW_ROUNDS )); then
      printf 'complete\n'
      return
    fi

    if [[ ! -s "${RUN_IMPL_DIR}/codex.revise-round-${round}.md" ]]; then
      printf 'revise-round-%s\n' "${round}"
      return
    fi
  done

  printf 'complete\n'
}

resolve_run_dir() {
  local ref="$1"
  local candidate

  if [[ -d "${ref}" ]]; then
    printf '%s\n' "${ref}"
    return
  fi

  candidate="${RUNS_DIR}/${ref}"
  if [[ -d "${candidate}" ]]; then
    printf '%s\n' "${candidate}"
    return
  fi

  candidate="${REPO_ROOT}/council-out/runs/${ref}"
  if [[ -d "${candidate}" ]]; then
    printf '%s\n' "${candidate}"
    return
  fi

  die "run not found: ${ref}"
}

require_workspace_match() {
  local expected="$1"
  local cwd
  cwd=$(current_path)

  [[ "${cwd}" == "${expected}" ]] || die "run this command from the run workspace: ${expected}"
}

load_run_context_from_dir() {
  local run_dir="$1"
  local run_id task workspace instance

  run_id=$(basename "${run_dir}")
  task=$(read_file_contents "${run_dir}/task.txt")
  workspace=$(read_file_contents "${run_dir}/workspace.txt")
  instance="default"
  if [[ -f "${run_dir}/instance.txt" ]]; then
    instance=$(read_file_contents "${run_dir}/instance.txt")
  fi

  apply_council_instance "${instance}"
  set_council_paths "${workspace}"
  ensure_dirs
  set_run_context "${run_id}" "${run_dir}" "${workspace}" "${task}"
  read_run_target >/dev/null
  read_run_phase >/dev/null
}

initialize_run() {
  local task="$1"
  local workspace="$2"
  local target="${3:-complete}"
  local run_id run_dir

  set_council_paths "${workspace}"
  ensure_dirs
  run_id=$(date +%Y%m%d-%H%M%S)-$$
  run_dir="${RUNS_DIR}/${run_id}"

  mkdir -p \
    "${run_dir}/plans" \
    "${run_dir}/critiques" \
    "${run_dir}/reviews" \
    "${run_dir}/implementation" \
    "${run_dir}/instructions" \
    "${run_dir}/bundles"

  printf "%s\n" "${task}" > "${run_dir}/task.txt"
  printf "%s\n" "${workspace}" > "${run_dir}/workspace.txt"
  printf "%s\n" "${COUNCIL_INSTANCE}" > "${run_dir}/instance.txt"

  set_run_context "${run_id}" "${run_dir}" "${workspace}" "${task}"
  write_run_target "${target}"
  write_run_phase "planning"
}

run_stage_plans() {
  local members=()
  local member role label instruction artifact

  while IFS= read -r member; do
    members+=("${member}")
  done < <(run_members)

  log_run_stage "plans" "collecting independent plans"

  for member in "${members[@]}"; do
    role=${member%%:*}
    label=${member##*:}
    artifact="${RUN_PLAN_DIR}/${role}.md"
    instruction="${RUN_INSTRUCTION_DIR}/plan-${role}.md"
    render_instruction "${REPO_ROOT}/templates/plan.md.tmpl" "${instruction}" "${RUN_ID}" "${RUN_WORKSPACE}" "${RUN_TASK}" "${artifact}" "" "${role}"
    if [[ ! -s "${artifact}" ]]; then
      send_instruction "${label}" "${instruction}"
    fi
  done

  wait_for_files "${DEFAULT_TIMEOUT}" \
    "${RUN_PLAN_DIR}/codex.md" "${RUN_PLAN_DIR}/cc.md" "${RUN_PLAN_DIR}/amp.md"

  write_bundle \
    "${RUN_BUNDLE_DIR}/plans.md" \
    "Council Plans" \
    "${RUN_TASK}" \
    "codex" "${RUN_PLAN_DIR}/codex.md" \
    "cc" "${RUN_PLAN_DIR}/cc.md" \
    "amp" "${RUN_PLAN_DIR}/amp.md"

  log_run_stage "plans-complete" "plans complete; critique stage is ready"
}

run_stage_critiques() {
  local members=()
  local member role label instruction artifact

  while IFS= read -r member; do
    members+=("${member}")
  done < <(run_members)

  log_run_stage "critiques" "dispatching critique bundle"

  for member in "${members[@]}"; do
    role=${member%%:*}
    label=${member##*:}
    artifact="${RUN_CRITIQUE_DIR}/${role}.md"
    instruction="${RUN_INSTRUCTION_DIR}/critique-${role}.md"
    render_instruction "${REPO_ROOT}/templates/critique.md.tmpl" "${instruction}" "${RUN_ID}" "${RUN_WORKSPACE}" "${RUN_TASK}" "${artifact}" "${RUN_BUNDLE_DIR}/plans.md" "${role}"
    if [[ ! -s "${artifact}" ]]; then
      send_instruction "${label}" "${instruction}"
    fi
  done

  wait_for_files "${DEFAULT_TIMEOUT}" \
    "${RUN_CRITIQUE_DIR}/codex.md" "${RUN_CRITIQUE_DIR}/cc.md" "${RUN_CRITIQUE_DIR}/amp.md"

  write_bundle \
    "${RUN_BUNDLE_DIR}/critiques.md" \
    "Council Critiques" \
    "${RUN_TASK}" \
    "codex" "${RUN_CRITIQUE_DIR}/codex.md" \
    "cc" "${RUN_CRITIQUE_DIR}/cc.md" \
    "amp" "${RUN_CRITIQUE_DIR}/amp.md"

  log_run_stage "critiques-complete" "critiques complete; final plan stage is ready"
}

run_stage_final_plan() {
  local instruction="${RUN_INSTRUCTION_DIR}/final-plan-codex.md"

  log_run_stage "final-plan" "requesting the final implementation plan from codex"

  render_instruction "${REPO_ROOT}/templates/final-plan.md.tmpl" \
    "${instruction}" \
    "${RUN_ID}" "${RUN_WORKSPACE}" "${RUN_TASK}" "${RUN_DIR}/plan.final.md" "${RUN_BUNDLE_DIR}/critiques.md" "codex"

  if [[ ! -s "${RUN_DIR}/plan.final.md" ]]; then
    send_instruction "${CODEX_LABEL}" "${instruction}"
  fi

  wait_for_file "${RUN_DIR}/plan.final.md"
  write_workspace_snapshot
  write_run_phase "plan-complete"
  log_run_stage "final-plan-complete" "final plan complete; execution is ready"
}

run_stage_implementation() {
  local instruction="${RUN_INSTRUCTION_DIR}/implement-codex.md"

  write_run_phase "execution"
  log_run_stage "implementation" "sending implementation work to codex"

  render_instruction "${REPO_ROOT}/templates/implement.md.tmpl" \
    "${instruction}" \
    "${RUN_ID}" "${RUN_WORKSPACE}" "${RUN_TASK}" "${RUN_IMPL_DIR}/codex.md" "${RUN_DIR}/plan.final.md" "codex"

  if [[ ! -s "${RUN_IMPL_DIR}/codex.md" ]]; then
    send_instruction "${CODEX_LABEL}" "${instruction}"
  fi

  wait_for_file "${RUN_IMPL_DIR}/codex.md"
  log_run_stage "implementation-complete" "implementation complete; review stage is ready"
}

run_stage_reviews() {
  local round role label artifact instruction

  for (( round = 1; round <= MAX_REVIEW_ROUNDS; round++ )); do
    log_run_stage "reviews-round-${round}" "dispatching review round ${round}"

    for role in cc amp; do
      if [[ "${role}" == "cc" ]]; then
        label="${CC_LABEL}"
      else
        label="${AMP_LABEL}"
      fi

      artifact="${RUN_REVIEW_DIR}/${role}.round-${round}.md"
      instruction="${RUN_INSTRUCTION_DIR}/review-${role}.round-${round}.md"
      render_instruction "${REPO_ROOT}/templates/review.md.tmpl" "${instruction}" "${RUN_ID}" "${RUN_WORKSPACE}" "${RUN_TASK}" "${artifact}" "${RUN_DIR}/plan.final.md" "${role}"
      if [[ ! -s "${artifact}" ]]; then
        send_instruction "${label}" "${instruction}"
      fi
    done

    wait_for_files "${DEFAULT_TIMEOUT}" \
      "${RUN_REVIEW_DIR}/cc.round-${round}.md" \
      "${RUN_REVIEW_DIR}/amp.round-${round}.md"

    review_round_verdicts "${round}"

    if [[ "${RUN_CC_VERDICT}" == "LGTM" && "${RUN_AMP_VERDICT}" == "LGTM" ]]; then
      write_run_phase "complete"
      log_run_stage "reviews-complete" "review round ${round} approved the implementation"
      return
    fi

    if (( round >= MAX_REVIEW_ROUNDS )); then
      write_run_phase "complete"
      log_run_stage "reviews-complete" "review rounds exhausted; keeping the final reviewer verdicts"
      return
    fi

    write_bundle \
      "${RUN_BUNDLE_DIR}/reviews.round-${round}.md" \
      "Council Reviews Round ${round}" \
      "${RUN_TASK}" \
      "cc" "${RUN_REVIEW_DIR}/cc.round-${round}.md" \
      "amp" "${RUN_REVIEW_DIR}/amp.round-${round}.md"

    artifact="${RUN_IMPL_DIR}/codex.revise-round-${round}.md"
    instruction="${RUN_INSTRUCTION_DIR}/revise-codex.round-${round}.md"
    log_run_stage "revise-round-${round}" "sending review findings back to codex"
    render_instruction "${REPO_ROOT}/templates/revise.md.tmpl" \
      "${instruction}" \
      "${RUN_ID}" "${RUN_WORKSPACE}" "${RUN_TASK}" "${artifact}" "${RUN_BUNDLE_DIR}/reviews.round-${round}.md" "codex"
    if [[ ! -s "${artifact}" ]]; then
      send_instruction "${CODEX_LABEL}" "${instruction}"
    fi
    wait_for_file "${artifact}"
  done
}

run_planning_pipeline() {
  local next_stage="${1:-$(next_stage_for_run)}"

  write_run_phase "planning"

  case "${next_stage}" in
    plans)
      run_stage_plans
      run_stage_critiques
      run_stage_final_plan
      ;;
    critiques)
      run_stage_critiques
      run_stage_final_plan
      ;;
    final-plan)
      run_stage_final_plan
      ;;
    complete)
      return
      ;;
    *)
      die "unexpected planning stage: ${next_stage}"
      ;;
  esac
}

run_execution_pipeline() {
  local next_stage="${1:-$(next_stage_for_run)}"

  case "${next_stage}" in
    implementation)
      run_stage_implementation
      run_stage_reviews
      ;;
    reviews-round-*|revise-round-*)
      run_stage_reviews
      ;;
    complete)
      return
      ;;
    *)
      die "unexpected execution stage: ${next_stage}"
      ;;
  esac
}

run_pipeline_to_target() {
  local next_stage="${1:-$(next_stage_for_run)}"

  if [[ "${next_stage}" == "complete" ]]; then
    return
  fi

  case "${next_stage}" in
    plans|critiques|final-plan)
      run_planning_pipeline "${next_stage}"
      next_stage=$(next_stage_for_run)
      ;;
  esac

  if [[ "${next_stage}" == "complete" ]]; then
    return
  fi

  run_execution_pipeline "${next_stage}"
}

run_pipeline() {
  run_pipeline_to_target "$(next_stage_for_run)"
}

print_run_summary() {
  local phase target stage

  phase=$(read_run_phase)
  target=$(read_run_target)
  stage=$(next_stage_for_run)

  print_heading "council run status"
  print_path_field "run" "${RUN_DIR}"
  print_field "instance" "${COUNCIL_INSTANCE}"
  print_field "phase" "${phase}"
  print_field "target" "${target}"
  print_field "stage" "${stage}"
  print_path_field "final plan" "${RUN_DIR}/plan.final.md"

  if [[ -s "${RUN_IMPL_DIR}/codex.md" ]]; then
    print_path_field "implementation note" "${RUN_IMPL_DIR}/codex.md"
    printf '%breviews:%b\n' "${STYLE_KEY}" "${STYLE_RESET}"
    print_review_item "${RUN_CC_REVIEW_PATH}" "${RUN_CC_VERDICT:-UNKNOWN}"
    print_review_item "${RUN_AMP_REVIEW_PATH}" "${RUN_AMP_VERDICT:-UNKNOWN}"
  elif [[ "${target}" == "plan" && "${stage}" == "complete" ]]; then
    print_field "next action" "council exec ${RUN_ID}"
  fi
}

current_session_target() {
  if [[ -n "${TMUX_PANE:-}" ]]; then
    tmux display-message -p -t "${TMUX_PANE}" '#{session_id}'
  else
    tmux display-message -p '#{session_id}'
  fi
}

current_session_name() {
  if [[ -n "${TMUX_PANE:-}" ]]; then
    tmux display-message -p -t "${TMUX_PANE}" '#{session_name}'
  else
    tmux display-message -p '#S'
  fi
}

current_window_name() {
  if [[ -n "${TMUX_PANE:-}" ]]; then
    tmux display-message -p -t "${TMUX_PANE}" '#{window_name}'
  else
    tmux display-message -p '#W'
  fi
}

current_path() {
  if [[ -n "${TMUX_PANE:-}" ]]; then
    tmux display-message -p -t "${TMUX_PANE}" '#{pane_current_path}'
  else
    tmux display-message -p '#{pane_current_path}'
  fi
}

window_target() {
  local session
  session=$(current_session_target)
  echo "${session}:${WINDOW_NAME}"
}

window_display_target() {
  local session_name
  session_name=$(current_session_name)
  echo "${session_name}:${WINDOW_NAME}"
}

quote_command_args() {
  local quoted="" arg

  for arg in "$@"; do
    printf -v quoted '%s%q ' "${quoted}" "${arg}"
  done

  printf '%s\n' "${quoted% }"
}

window_exists() {
  tmux list-windows -t "$(current_session_target)" -F '#W' | grep -Fx "${WINDOW_NAME}" >/dev/null 2>&1
}

window_name_exists() {
  local name="$1"
  tmux list-windows -t "$(current_session_target)" -F '#W' | grep -Fx "${name}" >/dev/null 2>&1
}

council_workspace() {
  tmux show-options -w -v -t "$(window_target)" @maestro_council_workspace 2>/dev/null || true
}

council_labels_ready() {
  local target
  target=$(window_target)
  [[ "$(tmux list-panes -t "${target}" -F '#{pane_id}' | wc -l | tr -d ' ')" -ge 3 ]] \
    && tmux list-panes -t "${target}" -F '#{@name}' | grep -Fx "${CODEX_LABEL}" >/dev/null 2>&1 \
    && tmux list-panes -t "${target}" -F '#{@name}' | grep -Fx "${CC_LABEL}" >/dev/null 2>&1 \
    && tmux list-panes -t "${target}" -F '#{@name}' | grep -Fx "${AMP_LABEL}" >/dev/null 2>&1
}

cache_pane_ids() {
  local target pane_id pane_name
  PANE_ID_CODEX=""
  PANE_ID_CC=""
  PANE_ID_AMP=""
  PANE_ID_ORCHESTRATOR=""
  target=$(window_target)
  while IFS=$'\t' read -r pane_id pane_name; do
    case "${pane_name}" in
      "${CODEX_LABEL}") PANE_ID_CODEX="${pane_id}" ;;
      "${CC_LABEL}")    PANE_ID_CC="${pane_id}" ;;
      "${AMP_LABEL}")   PANE_ID_AMP="${pane_id}" ;;
      "${ORCHESTRATOR_LABEL}") PANE_ID_ORCHESTRATOR="${pane_id}" ;;
    esac
  done < <(tmux list-panes -t "${target}" -F '#{pane_id}	#{@name}')

  [[ -n "${PANE_ID_CODEX}" ]] || die "cache_pane_ids: no pane for ${CODEX_LABEL}"
  [[ -n "${PANE_ID_CC}" ]]    || die "cache_pane_ids: no pane for ${CC_LABEL}"
  [[ -n "${PANE_ID_AMP}" ]]   || die "cache_pane_ids: no pane for ${AMP_LABEL}"
}

select_run_instance() {
  local base candidate counter window_name

  (( INSTANCE_IS_EXPLICIT == 0 )) || return 0

  candidate="${COUNCIL_INSTANCE:-default}"
  window_name=$(window_name_for_instance "${candidate}")
  if ! window_name_exists "${window_name}"; then
    return 0
  fi

  base="${candidate}"
  counter=2
  while true; do
    candidate="${base}-${counter}"
    window_name=$(window_name_for_instance "${candidate}")
    if ! window_name_exists "${window_name}"; then
      apply_council_instance "${candidate}"
      return 0
    fi
    counter=$((counter + 1))
  done
}

resolve_target() {
  local target="$1"
  case "${target}" in
    "${CODEX_LABEL}") echo "${PANE_ID_CODEX}" ;;
    "${CC_LABEL}")    echo "${PANE_ID_CC}" ;;
    "${AMP_LABEL}")   echo "${PANE_ID_AMP}" ;;
    %*)               echo "${target}" ;;
    *)                return 1 ;;
  esac
}

send_instruction() {
  local label="$1"
  local instruction="$2"
  local message="Council task ready. Read and execute: ${instruction}"
  local pane_id

  pane_id=$(resolve_target "${label}") || die "cannot resolve target: ${label}"

  if [[ "${label}" == "${CODEX_LABEL}" ]]; then
    if ! tmux send-keys -t "${pane_id}" -l -- "${message}" >/dev/null 2>&1; then
      cache_pane_ids
      pane_id=$(resolve_target "${label}") || die "cannot resolve target after refresh: ${label}"
      tmux send-keys -t "${pane_id}" -l -- "${message}" >/dev/null || die "send failed for ${label} after cache refresh"
    fi
    sleep 0.1
    tmux send-keys -t "${pane_id}" Enter >/dev/null || die "enter send failed for ${label}"
    return 0
  fi

  if ! tmux-bridge send "${pane_id}" "${message}" >/dev/null 2>&1; then
    cache_pane_ids
    pane_id=$(resolve_target "${label}") || die "cannot resolve target after refresh: ${label}"
    tmux-bridge send "${pane_id}" "${message}" >/dev/null || die "send failed for ${label} after cache refresh"
  fi
}

safe_notice() {
  local label="$1"
  local message="$2"
  local pane_id

  pane_id=$(resolve_target "${label}" 2>/dev/null) || return 0
  tmux-bridge send "${pane_id}" "${message}" >/dev/null 2>&1 || return 0
}

wait_for_file() {
  local path="$1"
  local timeout="${2:-${DEFAULT_TIMEOUT}}"
  local deadline=$((SECONDS + timeout))

  while [[ ! -s "${path}" ]]; do
    if (( SECONDS >= deadline )); then
      echo "timed out waiting for ${path}" >&2
      return 1
    fi
    sleep "${POLL_INTERVAL}"
  done
}

wait_for_files() {
  local timeout="${1}"; shift
  local pids=() paths=("$@")
  local i

  for i in "${!paths[@]}"; do
    wait_for_file "${paths[$i]}" "${timeout}" &
    pids+=($!)
  done

  local failed=()
  for i in "${!pids[@]}"; do
    if ! wait "${pids[$i]}"; then
      failed+=("${paths[$i]}")
    fi
  done

  if (( ${#failed[@]} > 0 )); then
    die "timed out waiting for: ${failed[*]}"
  fi
}

render_template() {
  local template="$1"
  local output="$2"
  local run_id="$3"
  local workspace="$4"
  local task="$5"
  local artifact="$6"
  local bundle="${7:-}"
  local role="${8:-}"
  local artifact_tmp="${artifact}.tmp"

  MC_RUN_ID="${run_id}" \
  MC_WORKSPACE="${workspace}" \
  MC_TASK="${task}" \
  MC_ARTIFACT="${artifact}" \
  MC_ARTIFACT_TMP="${artifact_tmp}" \
  MC_BUNDLE="${bundle}" \
  MC_ROLE="${role}" \
  perl -0pe '
    s/\{\{RUN_ID\}\}/$ENV{MC_RUN_ID}/g;
    s/\{\{WORKSPACE\}\}/$ENV{MC_WORKSPACE}/g;
    s/\{\{TASK\}\}/$ENV{MC_TASK}/g;
    s/\{\{ARTIFACT\}\}/$ENV{MC_ARTIFACT}/g;
    s/\{\{ARTIFACT_TMP\}\}/$ENV{MC_ARTIFACT_TMP}/g;
    s/\{\{BUNDLE\}\}/$ENV{MC_BUNDLE}/g;
    s/\{\{ROLE\}\}/$ENV{MC_ROLE}/g;
  ' "${template}" > "${output}"
}

append_instruction_tmux_context() {
  local instruction="$1"
  local role="$2"
  local session_name window_name
  local self_label self_pane
  local peer_one_role peer_one_label peer_one_pane
  local peer_two_role peer_two_label peer_two_pane

  cache_pane_ids
  session_name=$(current_session_name)
  window_name=$(window_display_target)

  case "${role}" in
    codex)
      self_label="${CODEX_LABEL}"
      self_pane="${PANE_ID_CODEX}"
      peer_one_role="cc"
      peer_one_label="${CC_LABEL}"
      peer_one_pane="${PANE_ID_CC}"
      peer_two_role="amp"
      peer_two_label="${AMP_LABEL}"
      peer_two_pane="${PANE_ID_AMP}"
      ;;
    cc)
      self_label="${CC_LABEL}"
      self_pane="${PANE_ID_CC}"
      peer_one_role="codex"
      peer_one_label="${CODEX_LABEL}"
      peer_one_pane="${PANE_ID_CODEX}"
      peer_two_role="amp"
      peer_two_label="${AMP_LABEL}"
      peer_two_pane="${PANE_ID_AMP}"
      ;;
    amp)
      self_label="${AMP_LABEL}"
      self_pane="${PANE_ID_AMP}"
      peer_one_role="codex"
      peer_one_label="${CODEX_LABEL}"
      peer_one_pane="${PANE_ID_CODEX}"
      peer_two_role="cc"
      peer_two_label="${CC_LABEL}"
      peer_two_pane="${PANE_ID_CC}"
      ;;
    *)
      return 0
      ;;
  esac

  cat >> "${instruction}" <<EOF

Tmux coordination:
- Current tmux session: ${session_name}
- Council window: ${window_name}
- Your pane target: ${self_pane} (${self_label})
- Other council peers in this same tmux session:
  - ${peer_one_role}: ${peer_one_pane} (${peer_one_label})
  - ${peer_two_role}: ${peer_two_pane} (${peer_two_label})
- If you need to contact a peer, target the pane ID above with tmux-bridge instead of relying on labels alone.
EOF
}

render_instruction() {
  local template="$1"
  local output="$2"
  local run_id="$3"
  local workspace="$4"
  local task="$5"
  local artifact="$6"
  local bundle="${7:-}"
  local role="${8:-}"

  render_template "${template}" "${output}" "${run_id}" "${workspace}" "${task}" "${artifact}" "${bundle}" "${role}"
  append_instruction_tmux_context "${output}" "${role}"
}

review_verdict() {
  local file="$1"
  awk '
    {
      line = toupper($0)
    }
    line ~ /^VERDICT:/ {
      split(line, fields)
      print fields[2]
      exit
    }
  ' "${file}"
}

write_bundle() {
  local output="$1"
  local title="$2"
  local task="$3"
  shift 3

  {
    printf '# %s\n\n' "${title}"
    printf 'Task: %s\n' "${task}"
    while [[ $# -gt 1 ]]; do
      local name="$1"
      local path="$2"
      shift 2
      printf '\n## %s\n' "${name}"
      cat "${path}"
      printf '\n'
    done
  } > "${output}"
}

agent_runner_script() {
  cat <<'EOF'
eval "$MAESTRO_COUNCIL_AGENT_CMD"
status=$?
printf '\n[maestro-council] agent exited with code %s. Dropping to shell.\n' "$status"
exec "$MAESTRO_COUNCIL_AGENT_SHELL" -i
EOF
}

orchestrator_runner_script() {
  cat <<'EOF'
eval "$MAESTRO_COUNCIL_ORCHESTRATOR_CMD"
status=$?
printf '\n[maestro-council] orchestration exited with code %s. Dropping to shell.\n' "$status"
exec "$MAESTRO_COUNCIL_ORCHESTRATOR_SHELL" -i
EOF
}

launch_agent_window() {
  local target_session="$1"
  local window_name="$2"
  local cwd="$3"
  local cmd="$4"
  local shell_bin="${SHELL:-/bin/zsh}"

  tmux new-window -t "${target_session}" -n "${window_name}" -c "${cwd}" \
    env MAESTRO_COUNCIL_AGENT_CMD="${cmd}" MAESTRO_COUNCIL_AGENT_SHELL="${shell_bin}" \
    "${shell_bin}" -lc "$(agent_runner_script)"
}

split_agent_pane() {
  local target="$1"
  local direction="$2"
  local cwd="$3"
  local cmd="$4"
  local shell_bin="${SHELL:-/bin/zsh}"

  tmux split-window "${direction}" -t "${target}" -c "${cwd}" \
    env MAESTRO_COUNCIL_AGENT_CMD="${cmd}" MAESTRO_COUNCIL_AGENT_SHELL="${shell_bin}" \
    "${shell_bin}" -lc "$(agent_runner_script)"
}

launch_orchestrator_pane() {
  local cwd="$1"
  local command="$2"
  local shell_bin="${SHELL:-/bin/zsh}"
  local target pane_id

  target="${TMUX_PANE:-$(tmux display-message -p '#{pane_id}')}"
  pane_id=$(
    tmux split-window -d -v -l "${ORCHESTRATOR_PANE_LINES}" -P -F '#{pane_id}' -t "${target}" -c "${cwd}" \
      env MAESTRO_COUNCIL_ORCHESTRATOR_CMD="${command}" MAESTRO_COUNCIL_ORCHESTRATOR_SHELL="${shell_bin}" \
      "${shell_bin}" -lc "$(orchestrator_runner_script)"
  ) || return 1

  printf '%s\n' "${pane_id}"
}

apply_council_orchestrator_layout() {
  local orchestrator_pane="$1"
  local codex_pane="$2"
  local cc_pane="$3"
  local amp_pane="$4"

  tmux break-pane -d -s "${cc_pane}" >/dev/null
  tmux break-pane -d -s "${amp_pane}" >/dev/null
  tmux break-pane -d -s "${codex_pane}" >/dev/null

  tmux join-pane -d -h -s "${cc_pane}" -t "${orchestrator_pane}"
  tmux join-pane -d -v -s "${codex_pane}" -t "${cc_pane}"
  tmux join-pane -d -h -s "${amp_pane}" -t "${cc_pane}"
  tmux resize-pane -t "${orchestrator_pane}" -x "${ORCHESTRATOR_PANE_WIDTH}"
  tmux select-pane -t "${orchestrator_pane}"
}

launch_orchestrator_pane_in_council_window() {
  local cwd="$1"
  local command="$2"
  local shell_bin="${SHELL:-/bin/zsh}"
  local target pane_id

  cache_pane_ids
  target=$(window_target)

  if [[ -n "${PANE_ID_ORCHESTRATOR}" ]]; then
    tmux respawn-pane -k -t "${PANE_ID_ORCHESTRATOR}" -c "${cwd}" \
      env MAESTRO_COUNCIL_ORCHESTRATOR_CMD="${command}" MAESTRO_COUNCIL_ORCHESTRATOR_SHELL="${shell_bin}" \
      "${shell_bin}" -lc "$(orchestrator_runner_script)"
    apply_council_orchestrator_layout "${PANE_ID_ORCHESTRATOR}" "${PANE_ID_CODEX}" "${PANE_ID_CC}" "${PANE_ID_AMP}"
    printf '%s\n' "${PANE_ID_ORCHESTRATOR}"
    return 0
  fi

  pane_id=$(
    tmux split-window -d -v -l "${ORCHESTRATOR_PANE_LINES}" -P -F '#{pane_id}' -t "${target}" -c "${cwd}" \
      env MAESTRO_COUNCIL_ORCHESTRATOR_CMD="${command}" MAESTRO_COUNCIL_ORCHESTRATOR_SHELL="${shell_bin}" \
      "${shell_bin}" -lc "$(orchestrator_runner_script)"
  ) || return 1

  tmux-bridge name "${pane_id}" "${ORCHESTRATOR_LABEL}" >/dev/null
  apply_council_orchestrator_layout "${pane_id}" "${PANE_ID_CODEX}" "${PANE_ID_CC}" "${PANE_ID_AMP}"
  printf '%s\n' "${pane_id}"
}

maybe_run_in_orchestrator_pane() {
  local command current_window cwd pane_id pane_target

  case "${ORCHESTRATE_IN_PANE}" in
    1|true|TRUE|yes|YES|on|ON) ;;
    *) return 1 ;;
  esac

  [[ "${MAESTRO_COUNCIL_IN_ORCHESTRATOR_PANE:-0}" != "1" ]] || return 1
  [[ -n "${TMUX_PANE:-}" ]] || return 1

  case "${ORCHESTRATOR_PANE_TARGET}" in
    current|CURRENT)
      pane_target="current"
      ;;
    council|COUNCIL)
      pane_target="council"
      ;;
    *)
      die "invalid MAESTRO_COUNCIL_ORCHESTRATOR_PANE_TARGET: ${ORCHESTRATOR_PANE_TARGET} (expected current or council)"
      ;;
  esac

  current_window=$(current_window_name)
  cwd=$(current_path)

  if [[ "${pane_target}" == "current" ]]; then
    case "${current_window}" in
      "${BASE_WINDOW_NAME}"|"${BASE_WINDOW_NAME}"-*) return 1 ;;
    esac
    command=$(quote_command_args env MAESTRO_COUNCIL_IN_ORCHESTRATOR_PANE=1 "${SCRIPT_DIR}/council" "$@")
    pane_id=$(launch_orchestrator_pane "${cwd}" "${command}") || return 1
    print_heading "council run launched"
    print_field "pane" "${pane_id}"
    print_field "location" "current window"
    print_note_line "follow the live status there; the pane stays open after the run completes"
    return 0
  fi

  select_run_instance
  start_council >/dev/null
  command=$(quote_command_args env MAESTRO_COUNCIL_IN_ORCHESTRATOR_PANE=1 MAESTRO_COUNCIL_INSTANCE="${COUNCIL_INSTANCE}" "${SCRIPT_DIR}/council" "$@")
  pane_id=$(launch_orchestrator_pane_in_council_window "${cwd}" "${command}") || return 1
  print_heading "council run launched"
  print_field "pane" "${pane_id}"
  print_field "location" "$(window_display_target)"
  print_note_line "follow the live status in the council window; the pane stays open after the run completes"
  return 0
}

agent_ready_pattern() {
  local label="$1"

  case "${label}" in
    "${CODEX_LABEL}")
      printf '%s\n' 'OpenAI Codex|/model to change|/rename to rename your threads'
      ;;
    "${CC_LABEL}")
      printf '%s\n' 'Claude Code|Welcome back|Claude Max|❯'
      ;;
    "${AMP_LABEL}")
      printf '%s\n' 'Welcome to Amp|Ctrl\+O for help|\? for shortcuts'
      ;;
    *)
      printf '%s\n' '.'
      ;;
  esac
}

wait_for_agent_ready() {
  local label="$1"
  local timeout="${2:-${AGENT_READY_TIMEOUT}}"
  local pane_id pattern output waited=0

  pane_id=$(resolve_target "${label}" 2>/dev/null || true)
  if [[ -z "${pane_id}" ]]; then
    cache_pane_ids
    pane_id=$(resolve_target "${label}" 2>/dev/null || true)
  fi
  [[ -n "${pane_id}" ]] || die "no pane found with label '${label}'"
  pattern=$(agent_ready_pattern "${label}")

  while true; do
    output=$(tmux capture-pane -t "${pane_id}" -p -S -40 2>/dev/null || true)
    if printf '%s\n' "${output}" | grep -Eq "${pattern}"; then
      return
    fi

    if (( waited >= timeout )); then
      die "timed out waiting for ${label} to become ready"
    fi

    sleep 1
    waited=$((waited + 1))
  done
}

wait_for_agents_ready() {
  local label
  for label in "${CODEX_LABEL}" "${CC_LABEL}" "${AMP_LABEL}"; do
    wait_for_agent_ready "${label}"
  done
}

cleanup_run() {
  local exit_code="$1"

  if [[ -n "${CURRENT_RUN_DIR}" ]]; then
    if (( exit_code == 0 )); then
      printf 'SUCCESS\n' > "${CURRENT_RUN_DIR}/status.txt"
    else
      printf 'FAILED\n' > "${CURRENT_RUN_DIR}/status.txt"
    fi
  fi

  if (( exit_code != 0 )) && [[ -n "${CURRENT_RUN_ID}" && -n "${CURRENT_MEMBER_LABELS}" ]]; then
    local label
    for label in ${CURRENT_MEMBER_LABELS}; do
      safe_notice "${label}" "Council run ${CURRENT_RUN_ID} was cancelled or failed. Ignore its previous instructions if you are still working on them."
    done
  fi
}

start_council() {
  local force_recreate="${1:-}"
  require_tmux

  local session_target cwd target display_target
  session_target=$(current_session_target)
  cwd=$(current_path)
  set_council_paths "${cwd}"
  ensure_dirs
  target=$(window_target)
  display_target=$(window_display_target)

  if window_exists; then
    if [[ "${force_recreate}" == "--force" ]]; then
      echo "recreating council window on request: ${display_target}" >&2
      tmux kill-window -t "${target}"
    else
      local existing_workspace
      existing_workspace=$(council_workspace)

      if council_labels_ready && [[ "${existing_workspace}" == "${cwd}" ]]; then
        cache_pane_ids
        tmux select-window -t "${target}"
        echo "selected existing council window: ${display_target}"
        return
      fi

      if [[ -n "${existing_workspace}" && "${existing_workspace}" != "${cwd}" ]]; then
        echo "recreating council window for workspace change: ${existing_workspace} -> ${cwd}" >&2
      else
        echo "recreating invalid council window: ${display_target}" >&2
      fi
      tmux kill-window -t "${target}"
    fi
  fi

  launch_agent_window "${session_target}" "${WINDOW_NAME}" "${cwd}" "${CODEX_CMD}"
  split_agent_pane "${target}" -h "${cwd}" "${CC_CMD}"
  split_agent_pane "${target}" -v "${cwd}" "${AMP_CMD}"
  tmux select-layout -t "${target}" tiled

  local panes=()
  local pane_id
  while IFS= read -r pane_id; do
    panes+=("${pane_id}")
  done < <(tmux list-panes -t "${target}" -F '#{pane_id}')
  [[ "${#panes[@]}" -eq 3 ]] || die "expected 3 panes, got ${#panes[@]}"

  tmux-bridge name "${panes[0]}" "${CODEX_LABEL}"
  tmux-bridge name "${panes[1]}" "${CC_LABEL}"
  tmux-bridge name "${panes[2]}" "${AMP_LABEL}"
  tmux set-option -w -t "${target}" @maestro_council_workspace "${cwd}"
  cache_pane_ids

  tmux select-window -t "${target}"
  tmux select-pane -t "${panes[0]}"
  wait_for_agents_ready

  print_heading "council started"
  print_field "window" "${display_target}"
  print_field "instance" "${COUNCIL_INSTANCE}"
  print_field "codex" "${CODEX_LABEL}"
  print_field "cc" "${CC_LABEL}"
  print_field "amp" "${AMP_LABEL}"
  print_path_field "workspace" "${cwd}"
}

status_council() {
  require_tmux
  if [[ "${1:-}" == "--all" ]]; then
    tmux-bridge list | grep -F -e "${BASE_WINDOW_NAME}" -e "${BASE_CODEX_LABEL}" -e "${BASE_CC_LABEL}" -e "${BASE_AMP_LABEL}" || true
    return
  fi

  tmux-bridge list | grep -F -e "${CODEX_LABEL}" -e "${CC_LABEL}" -e "${AMP_LABEL}" -e "${WINDOW_NAME}" || true
}

run_council() {
  require_tmux
  [[ $# -gt 0 ]] || die "usage: council run <task>"
  select_run_instance
  start_council >/dev/null

  local task workspace
  task="$*"
  workspace=$(council_workspace)
  [[ -n "${workspace}" ]] || die "council workspace is not set. Run 'council start' from the target workspace first."
  initialize_run "${task}" "${workspace}" "complete"
  setup_current_run_tracking
  trap 'cleanup_run $?' EXIT

  print_heading "council run started"
  print_path_field "run" "${RUN_DIR}"
  print_field "instance" "${COUNCIL_INSTANCE}"
  print_path_field "workspace" "${RUN_WORKSPACE}"
  print_field "resume" "council resume ${RUN_ID}"

  run_pipeline
  print_run_summary
  finalize_run_success
}

plan_council() {
  require_tmux
  [[ $# -gt 0 ]] || die "usage: council plan <task>"
  select_run_instance
  start_council >/dev/null

  local task workspace
  task="$*"
  workspace=$(council_workspace)
  [[ -n "${workspace}" ]] || die "council workspace is not set. Run 'council start' from the target workspace first."
  initialize_run "${task}" "${workspace}" "plan"
  setup_current_run_tracking
  trap 'cleanup_run $?' EXIT

  print_heading "council plan started"
  print_path_field "run" "${RUN_DIR}"
  print_field "instance" "${COUNCIL_INSTANCE}"
  print_path_field "workspace" "${RUN_WORKSPACE}"
  print_field "resume" "council resume ${RUN_ID}"

  run_pipeline
  print_run_summary
  finalize_run_success
}

exec_council() {
  require_tmux
  [[ $# -eq 1 ]] || die "usage: council exec <run-id-or-path>"

  local run_ref run_dir next_stage snapshot_path
  run_ref="$1"

  set_council_paths "$(current_path)"
  run_dir=$(resolve_run_dir "${run_ref}")
  load_run_context_from_dir "${run_dir}"
  [[ -s "${RUN_DIR}/plan.final.md" ]] || die "plan phase is not complete for run ${RUN_ID}"

  snapshot_path=$(run_workspace_snapshot_path)
  [[ -f "${snapshot_path}" ]] || die "missing workspace snapshot for run ${RUN_ID}; re-run planning before execution"

  require_workspace_match "${RUN_WORKSPACE}"
  check_workspace_snapshot || die "workspace drift detected since planning; inspect ${snapshot_path} or re-run council plan"

  start_council --force >/dev/null
  write_run_target "complete"
  setup_current_run_tracking
  trap 'cleanup_run $?' EXIT

  next_stage=$(next_stage_for_run)
  print_heading "council exec"
  print_path_field "run" "${RUN_DIR}"
  print_field "instance" "${COUNCIL_INSTANCE}"
  print_path_field "workspace" "${RUN_WORKSPACE}"
  print_field "next stage" "${next_stage}"

  if [[ "${next_stage}" == "complete" ]]; then
    print_run_summary
    finalize_run_success
    return
  fi

  run_execution_pipeline "${next_stage}"
  print_run_summary
  finalize_run_success
}

resume_council() {
  require_tmux
  [[ $# -gt 0 ]] || die "usage: council resume <run-id-or-path>"

  local run_ref run_dir next_stage
  run_ref="$1"

  set_council_paths "$(current_path)"
  run_dir=$(resolve_run_dir "${run_ref}")
  load_run_context_from_dir "${run_dir}"
  require_workspace_match "${RUN_WORKSPACE}"
  start_council >/dev/null

  setup_current_run_tracking
  trap 'cleanup_run $?' EXIT

  next_stage=$(next_stage_for_run)
  print_heading "council resume"
  print_path_field "run" "${RUN_DIR}"
  print_field "instance" "${COUNCIL_INSTANCE}"
  print_path_field "workspace" "${RUN_WORKSPACE}"
  print_field "next stage" "${next_stage}"

  if [[ "${next_stage}" == "complete" ]]; then
    print_run_summary
    finalize_run_success
    return
  fi

  run_pipeline_to_target "${next_stage}"
  print_run_summary
  finalize_run_success
}

usage() {
  cat <<EOF
council

Usage:
  council start [--force] [--instance <name>]
  council reset [--instance <name>]
  council status [--instance <name>]
  council status --all
  council plan [--instance <name>] <task>
  council exec <run-id-or-path>
  council run [--instance <name>] <task>
  council run [--instance <name>] -- <task starting with dashes>
  council resume <run-id-or-path>
  council continue <run-id-or-path>
EOF
}

parse_instance_option() {
  [[ $# -gt 0 ]] || die "missing value for --instance"
  INSTANCE_IS_EXPLICIT=1
  apply_council_instance "$1"
}

main() {
  local original_args=("$@")
  local cmd="${1:-}"
  shift || true

  if [[ "${MAESTRO_COUNCIL_INSTANCE+x}" == "x" ]]; then
    INSTANCE_IS_EXPLICIT=1
  fi
  apply_council_instance "${MAESTRO_COUNCIL_INSTANCE:-default}"

  case "${cmd}" in
    start)
      local force=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --force)
            force="--force"
            ;;
          --instance|-i)
            shift || true
            parse_instance_option "$@"
            ;;
          *)
            die "usage: council start [--force] [--instance <name>]"
            ;;
        esac
        shift || true
      done
      start_council "${force}"
      ;;
    reset)
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --instance|-i)
            shift || true
            parse_instance_option "$@"
            ;;
          *)
            die "usage: council reset [--instance <name>]"
            ;;
        esac
        shift || true
      done
      start_council --force
      ;;
    status)
      local list_all=""
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --instance|-i)
            shift || true
            parse_instance_option "$@"
            ;;
          --all)
            list_all="--all"
            ;;
          *)
            die "usage: council status [--instance <name>] [--all]"
            ;;
        esac
        shift || true
      done
      status_council "${list_all}"
      ;;
    plan)
      local task_args=()
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --instance|-i)
            shift || true
            parse_instance_option "$@"
            ;;
          --)
            shift || true
            task_args+=("$@")
            break
            ;;
          -*)
            die "usage: council plan [--instance <name>] <task>"
            ;;
          *)
            task_args+=("$@")
            break
            ;;
        esac
        shift || true
      done
      plan_council "${task_args[@]}"
      ;;
    exec)
      [[ $# -eq 1 ]] || die "usage: council exec <run-id-or-path>"
      exec_council "$1"
      ;;
    run)
      local task_args=()
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --instance|-i)
            shift || true
            parse_instance_option "$@"
            ;;
          --)
            shift || true
            task_args+=("$@")
            break
            ;;
          -*)
            die "usage: council run [--instance <name>] <task>"
            ;;
          *)
            task_args+=("$@")
            break
            ;;
        esac
        shift || true
      done
      if maybe_run_in_orchestrator_pane "${original_args[@]}"; then
        return 0
      fi
      run_council "${task_args[@]}"
      ;;
    resume|continue)
      [[ $# -eq 1 ]] || die "usage: council ${cmd} <run-id-or-path>"
      resume_council "$1"
      ;;
    -h|--help|help|"")
      usage
      ;;
    *)
      die "unknown command: ${cmd}"
      ;;
  esac
}

main "$@"
